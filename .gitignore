# .gitignore

# Python-related
*.pyc
__pycache__/
*.pyo

# Environment variables
.env

# Database
instance/db.sqlite

# IDE and text editor specific files
.vscode/
.idea/

# Compiled Python files
*.pyc

# Local development configurations
instance/

# Virtual environment
venv/

# Editor-specific files
*.swp

# Logs
logs/
*.log

# Git-related files
.git

# Ignore pycache folders generated by specific Python versions (replace with your Python version)
*.cpython-37/
*.cpython-38/
*.cpython-39/

# Ignore pycache folders generated by specific Python versions
__pycache__/config.cpython-37.pyc
__pycache__/models.cpython-37.pyc
__pycache__/config.cpython-38.pyc
__pycache__/models.cpython-38.pyc
__pycache__/config.cpython-39.pyc
__pycache__/models.cpython-39.pyc
